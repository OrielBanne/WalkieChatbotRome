# ============================================================================
# OpenAI Configuration
# ============================================================================
# IMPORTANT: Set your OpenAI API key as a system environment variable
# 
# Option 1: PowerShell (Recommended for Windows)
# [System.Environment]::SetEnvironmentVariable('OPENAI_API_KEY', 'your-key-here', 'User')
#
# Option 2: Windows GUI
# System Properties > Advanced > Environment Variables > User Variables > New
# Variable name: OPENAI_API_KEY
# Variable value: your-key-here
#
# Option 3: Use .env file (NOT recommended for Git repos)
# Uncomment the line below and add your key:
# OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# Model Configuration
# ============================================================================
EMBEDDING_MODEL=text-embedding-ada-002
LLM_MODEL=gpt-3.5-turbo
SPACY_MODEL=en_core_web_sm

# ============================================================================
# Application Configuration
# ============================================================================
APP_TITLE=Rome Places Chatbot
MAX_CONTEXT_TOKENS=4000
RETRIEVAL_TOP_K=5

# ============================================================================
# Geographic Configuration
# ============================================================================
ROME_CENTER_LAT=41.9028
ROME_CENTER_LON=12.4964

# ============================================================================
# Geocoding Configuration
# ============================================================================
GEOCODING_USER_AGENT=rome_places_chatbot

# ============================================================================
# File Paths
# ============================================================================
SESSION_STORAGE_PATH=./sessions
VECTOR_STORE_PATH=./data/vector_store
DATA_DIR=./data

# ============================================================================
# Text Chunking Configuration
# ============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================================
# Session Management
# ============================================================================
SESSION_RETENTION_DAYS=90

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_RETRIEVAL_K=5
API_MAX_RETRIES=3
API_TIMEOUT=30

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
